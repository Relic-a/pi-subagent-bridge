{
  "name": "pi-subagent-bridge",
  "version": "0.2.0",
  "description": "Codex plugin for running isolated Pi coding-agent subprocesses through MCP.",
  "type": "module",
  "bin": {
    "pi-subagent-bridge": "scripts/install.mjs"
  },
  "files": [
    ".agents/plugins/marketplace.json",
    "plugins/pi-subagent-bridge/.codex-plugin/plugin.json",
    "plugins/pi-subagent-bridge/.mcp.json",
    "plugins/pi-subagent-bridge/server/dist",
    "plugins/pi-subagent-bridge/server/package.json",
    "plugins/pi-subagent-bridge/skills",
    "scripts/install.mjs",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "npm run build --prefix server && node scripts/sync-plugin.mjs",
    "postinstall": "node scripts/install.mjs --postinstall",
    "test:critical": "npm run typecheck --prefix server && npm run test:unit --prefix server && node scripts/sync-plugin.mjs --check && node scripts/validate-plugin.mjs --smoke",
    "prepack": "npm run build && npm run test:critical",
    "release:check": "npm pack --dry-run",
    "install:codex": "node scripts/install.mjs install"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "keywords": [
    "codex",
    "mcp",
    "pi",
    "subagent"
  ],
  "author": "Relic-a",
  "license": "MIT",
  "homepage": "https://github.com/Relic-a/pi-subagent-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Relic-a/pi-subagent-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/Relic-a/pi-subagent-bridge/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.3",
    "better-sqlite3": "^12.11.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.30",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
